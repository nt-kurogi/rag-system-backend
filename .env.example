# =========================
# RAG Backend Configuration
# =========================

# API server port
PORT=8787

# CORS allowed origin (React dev server URL)
ALLOWED_ORIGIN=http://localhost:5173

# Optional: if set, frontend must send same value in `api-key` header
BACKEND_API_KEY=

# -------------------------
# Azure OpenAI
# -------------------------
# Example: https://my-openai-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-openai-api-key>

# IMPORTANT: deployment name (not model name)
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>

# Not used in v1 Responses API (kept only for compatibility/reference).
AZURE_OPENAI_API_VERSION=

# -------------------------
# Azure AI Search
# -------------------------
# Example: https://my-search-service.search.windows.net
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<your-search-api-key>

# Default index used when request body has no indexName
AZURE_SEARCH_INDEX=<default-index-name>

# -------------------------
# Azure Blob SAS for citations (optional)
# -------------------------
# If your citation URLs point to private Blob Storage, set these to return SAS URLs.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
BLOB_SAS_EXPIRY_MINUTES=30
